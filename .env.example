# aigent.rocks — required environment variables
# Copy this file to .env and fill in real values for local dev.
# In production, set these in your Netlify site settings (Build & deploy → Environment).

# PostgreSQL connection string (Supabase / Neon / your own host)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# earnrm CRM API key — used by /api/contact when leads come in
EARNRM_API_KEY=your_earnrm_api_key_here

# Anthropic Claude API key — powers The Conductor chat widget
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
